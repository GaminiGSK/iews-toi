{
    "hosting": {
        "site": "gksmart-ai-app",
        "public": "client/dist",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "headers": [
            {
                "source": "/**/index.html",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "no-cache, no-store, must-revalidate"
                    }
                ]
            },
            {
                "source": "/assets/**",
                "headers": [
                    {
                        "key": "Cache-Control",
                        "value": "public, max-age=31536000, immutable"
                    }
                ]
            }
        ],
        "rewrites": [
            {
                "source": "/api/**",
                "run": {
                    "serviceId": "iews-toi",
                    "region": "asia-southeast1"
                }
            },
            {
                "source": "/socket.io/**",
                "run": {
                    "serviceId": "iews-toi",
                    "region": "asia-southeast1"
                }
            },
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    }
}